[0.001, "o", "\r\u001b[2K\u001b[32mв”ѓ\u001b[0m sed -n '6100,6250p' /Users/morinop/coding/yoga_framework/playground/vi                                                                                     \r\nm/src/buffer.c                                                                                                                                               \r\n                current_sctx.sc_seq = 0;                                                                                                                     \r\n                current_sctx.sc_lnum = lnum;                                                                                                                 \r\n#endif                                                                                                                                                       \r\n                                                                                                                                                             \r\n                // Make sure no risky things are execu"]
[0.000, "o", "ted as a side effect.                                                                                  \r\n                secure = 1;                                                                                                                                  \r\n                                                                                                                                                             \r\n                retval = do_set(s, OPT_MODELINE | OPT_LOCAL | flags);                                                                                        \r\n                                                                                                                                                             \r\n                secure = secure_save;                                                                                                                        \r\n                current_sctx = save_current_sctx;                                                                           "]
[0.000, "o", "                                 \r\n                if (retval == FAIL)             // stop if error found                                                                                       \r\n                    break;                                                                                                                                   \r\n            }                                                                                                                                                \r\n            s = (e == line_end) ? e : e + 1;    // advance to next part                                                                                      \r\n                                                // careful not to go off the end                                                                             \r\n        }                                                                                                                                                    \r\n                                   "]
[0.000, "o", "                                                                                                                          \r\n        ESTACK_CHECK_NOW;                                                                                                                                    \r\n        estack_pop();                                                                                                                                        \r\n        vim_free(linecopy);                                                                                                                                  \r\n    }                                                                                                                                                        \r\n    return retval;                                                                                                                                           \r\n}                                                                                                        "]
[0.000, "o", "                                                    \r\n                                                                                                                                                             \r\n/*                                                                                                                                                           \r\n * Return TRUE if \"buf\" is a normal buffer, 'buftype' is empty.                                                                                              \r\n */                                                                                                                                                          \r\n    int                                                                                                                                                      \r\nbt_normal(buf_T *buf)                                                                                                                                        \r\n{               "]
[0.000, "o", "                                                                                                                                             \r\n    return buf != NULL && buf->b_p_bt[0] == NUL;                                                                                                             \r\n}                                                                                                                                                            \r\n                                                                                                                                                             \r\n/*                                                                                                                                                           \r\n * Return TRUE if \"buf\" is the quickfix buffer.                                                                                                              \r\n */                                                                                   "]
[0.000, "o", "                                                                       \r\n    int                                                                                                                                                      \r\nbt_quickfix(buf_T *buf UNUSED)                                                                                                                               \r\n{                                                                                                                                                            \r\n#ifdef FEAT_QUICKFIX                                                                                                                                         \r\n    return buf != NULL && buf->b_p_bt[0] == 'q';                                                                                                             \r\n#else                                                                                                                                                       "]
[0.000, "o", " \r\n    return FALSE;                                                                                                                                            \r\n#endif                                                                                                                                                       \r\n}                                                                                                                                                            \r\n                                                                                                                                                             \r\n/*                                                                                                                                                           \r\n * Return TRUE if \"buf\" is a terminal buffer.                                                                                                                \r\n */                                                                "]
[0.000, "o", "                                                                                          \r\n    int                                                                                                                                                      \r\nbt_terminal(buf_T *buf UNUSED)                                                                                                                               \r\n{                                                                                                                                                            \r\n#if defined(FEAT_TERMINAL)                                                                                                                                   \r\n    return buf != NULL && buf->b_p_bt[0] == 't';                                                                                                             \r\n#else                                                                                                                                    "]
[0.000, "o", "                    \r\n    return FALSE;                                                                                                                                            \r\n#endif                                                                                                                                                       \r\n}                                                                                                                                                            \r\n                                                                                                                                                             \r\n/*                                                                                                                                                           \r\n * Return TRUE if \"buf\" is a help buffer.                                                                                                                    \r\n */                                             "]
[0.000, "o", "                                                                                                             \r\n    int                                                                                                                                                      \r\nbt_help(buf_T *buf)                                                                                                                                          \r\n{                                                                                                                                                            \r\n    return buf != NULL && buf->b_help;                                                                                                                       \r\n}                                                                                                                                                            \r\n                                                                                                                      "]
[0.000, "o", "                                       \r\n/*                                                                                                                                                           \r\n * Return TRUE if \"buf\" is a prompt buffer.                                                                                                                  \r\n */                                                                                                                                                          \r\n    int                                                                                                                                                      \r\nbt_prompt(buf_T *buf)                                                                                                                                        \r\n{                                                                                                                                                            \r\n    return buf != NULL && buf"]
[0.000, "o", "->b_p_bt[0] == 'p' && buf->b_p_bt[1] == 'r';                                                                                    \r\n}                                                                                                                                                            \r\n                                                                                                                                                             \r\n#if defined(FEAT_PROP_POPUP)                                                                                                                                 \r\n/*                                                                                                                                                           \r\n * Return TRUE if \"buf\" is a buffer for a popup window.                                                                                                      \r\n */                                                                                                "]
[0.000, "o", "                                                          \r\n    int                                                                                                                                                      \r\nbt_popup(buf_T *buf)                                                                                                                                         \r\n{                                                                                                                                                            \r\n    return buf != NULL && buf->b_p_bt != NULL                                                                                                                \r\n        && buf->b_p_bt[0] == 'p' && buf->b_p_bt[1] == 'o';                                                                                                   \r\n}                                                                                                                                                            \r\n#endif    "]
