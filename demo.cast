[0.003, "o", "\r\u001b[2K\u001b[32mв”ѓ\u001b[0m sed -n '5940,6100p' /Users/morinop/coding/yoga_framework/playground/vi                                                                                     \r\nm/src/buffer.c                                                                                                                                               \r\n                                                                                                                                                             \r\nstatic int  chk_modeline(linenr_T, int);                                                                                                                     \r\n                                                                                                                                                             \r\n/*                                                                                                                                                           \r\n * do_modelines() - process mode lines for the current"]
[0.000, "o", " file                                                                                                  \r\n *                                                                                                                                                           \r\n * \"flags\" can be:                                                                                                                                           \r\n * OPT_WINONLY      only set options local to window                                                                                                         \r\n * OPT_NOWIN        don't set options local to window                                                                                                        \r\n *                                                                                                                                                           \r\n * Returns immediately if the \"ml\" option isn't set.                                                                        "]
[0.000, "o", "                                 \r\n */                                                                                                                                                          \r\n    void                                                                                                                                                     \r\ndo_modelines(int flags)                                                                                                                                      \r\n{                                                                                                                                                            \r\n    linenr_T    lnum;                                                                                                                                        \r\n    int         nmlines;                                                                                                                                     \r\n    static int  entered = 0;       "]
[0.000, "o", "                                                                                                                          \r\n                                                                                                                                                             \r\n    if (!curbuf->b_p_ml || (nmlines = (int)p_mls) == 0)                                                                                                      \r\n        return;                                                                                                                                              \r\n                                                                                                                                                             \r\n    // Disallow recursive entry here.  Can happen when executing a modeline                                                                                  \r\n    // triggers an autocommand, which reloads modelines with a \":do\".                                    "]
[0.000, "o", "                                                    \r\n    if (entered)                                                                                                                                             \r\n        return;                                                                                                                                              \r\n                                                                                                                                                             \r\n    ++entered;                                                                                                                                               \r\n    for (lnum = 1; curbuf->b_p_ml && lnum <= curbuf->b_ml.ml_line_count && lnum                                                                              \r\n<= nmlines;                                                                                                                                                  \r\n                "]
[0.000, "o", "                                                       ++lnum)                                                                               \r\n        if (chk_modeline(lnum, flags) == FAIL)                                                                                                               \r\n            nmlines = 0;                                                                                                                                     \r\n                                                                                                                                                             \r\n    for (lnum = curbuf->b_ml.ml_line_count; curbuf->b_p_ml && lnum > 0 && lnum >                                                                             \r\n nmlines                                                                                                                                                     \r\n                       && lnum > curbuf->b_ml.ml_line_count - nmlines; --lnum)        "]
[0.000, "o", "                                                                       \r\n        if (chk_modeline(lnum, flags) == FAIL)                                                                                                               \r\n            nmlines = 0;                                                                                                                                     \r\n    --entered;                                                                                                                                               \r\n}                                                                                                                                                            \r\n                                                                                                                                                             \r\n#include \"version.h\"            // for version number                                                                                                       "]
[0.000, "o", " \r\n                                                                                                                                                             \r\n/*                                                                                                                                                           \r\n * chk_modeline() - check a single line for a mode string                                                                                                    \r\n * Return FAIL if an error encountered.                                                                                                                      \r\n */                                                                                                                                                          \r\n    static int                                                                                                                                               \r\nchk_modeline(                                                      "]
[0.000, "o", "                                                                                          \r\n    linenr_T    lnum,                                                                                                                                        \r\n    int         flags)          // Same as for do_modelines().                                                                                               \r\n{                                                                                                                                                            \r\n    char_u      *s;                                                                                                                                          \r\n    char_u      *line_end;              // point to the end of the line                                                                                      \r\n    char_u      *e;                                                                                                                      "]
[0.000, "o", "                    \r\n    int         prev;                                                                                                                                        \r\n    int         retval = OK;                                                                                                                                 \r\n    ESTACK_CHECK_DECLARATION;                                                                                                                                \r\n                                                                                                                                                             \r\n    prev = -1;                                                                                                                                               \r\n    s = ml_get(lnum);                                                                                                                                        \r\n    line_end = s + ml_get_len(lnum);            "]
[0.000, "o", "                                                                                                             \r\n    for (; *s != NUL; ++s)                                                                                                                                   \r\n    {                                                                                                                                                        \r\n        if (prev == -1 || vim_isspace(prev))                                                                                                                 \r\n        {                                                                                                                                                    \r\n            if ((prev != -1 && STRNCMP(s, \"ex:\", (size_t)3) == 0)                                                                                            \r\n                    || STRNCMP(s, \"vi... (truncated)                                                                  "]
